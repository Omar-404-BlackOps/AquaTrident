float Volt2pH(float voltage){
  float slope = (4.0 - 7.0) / (pH_Acidic_Voltage / pH_Neutral_Voltage);
  return 7.0 + slope * (voltage - pH_Neutral_Voltage);
}


void Show_Normal_Screen(float ph, float tds, float ntum bool aeratorON){
  lcd.setCursor(0,0); lcd.print(F("Aqua Trident.. "));
  lcd.setCursor(0,1); 
  lcd.print(F("pH: ")), lcd.print(pH,2); 
  if (areatorON) 
  lcd.print(F("  [AER] "));
  else 
  lcd.print(F("     "));
  lcd.setCursor(0,2);
  lcd.print(F*("TDS:  ")); lcd.print(tds,0);
  lcd.print(F("ppm    "));
  lcd.setCursor(0,3);
  lcd.print(F("Turb:  ")); lcd.print(ntu,1); lcd.print(F("NTU:  "));
}

