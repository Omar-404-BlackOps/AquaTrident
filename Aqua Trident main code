void handleActuators(float tds. float ntu, float ph){
  bool aeratorCurrentlyOn = (digitalRead(Areator) == LOW);
  if (ph < PH_LOW && !aeratorCurrentlyOn) {
    Relay_ON(Areator);
    if (!AlertShown_pH) {
      ShowAlert("!! ALERT: LOW pH !!"
                "pH too acidic",
                "Aerator Activated",
                "Injecting O2.......")
      AlertShown_pH = true;
    }
  } else if (ph >= PH_LOW + 0.3 && aeratorCurrentlyOn ) {
    Relay_OFF(Areator);
    AlertShown_pH = false; 
    lcd.clear(); 
  }

bool badWater = (tds > TDS_MAX) || (ntu > NTU_MAX);

if (!Flushing && badWater) {
  Flushing = true; 
  FlushStart = millis();
  Relay_ON(Valve);

  if (tds > TDS_MAX && ntu > NTU_MAX){
    ShowAlert("!! ALERT: FLUSH !!",
              "TDS + Turbidty HIGH",
            "Draining water...",
          "Please wait 10s....");
  } else if (tds > TDS_MAX){
    ShowAlert("!! ALERT: HIGH TDS",
              "Dissolved solids",
              "above 500 ppm",
             "Flushing system...");
  } else {
    ShowAlert("!! ALERT: TURBID..",
              "Water too cloudy",
              "above 50 NTU",
              "Flushing system...");
    }
    Serial.println(F("[FLUSH] Started.."));
  }

  if (Flushing){
    unsigned long elapsed = millis() - FlushStart;

    if (elapsed >= 5000UL && elapsed < Flush_Duration){
      Relay_ON(Pump);
      lcd.setCursor(0,2); lcd.print(F("Refilling water.."));
    }

    if (elapsed >= FlushStart){
      Relay_OFF(Valve);
      Relay_OFF(Pump);
      Flushing = false;
      lcd.clear();
      Serial.println(F("[FLUSH] Complete.."));
    }
  }
}

void setup() {
  Serial.begin(9600);


  pinMode(Pump, OUTPUT); Relay_OFF(Pump);
  pinMode(Valve, OUTPUT); Relay_OFF(Valve);
  pinMode(Areator, OUTPUT); Relay_OFF(Areator);


  lcd.init();
  lcd.backlight();
  lcd.setCursor(0,0); lcd.print(F(" Aqua  "));
  lcd.setCursor(0,1); lcd.print(F(" Trident "));
  lcd.setCursor(0,2); lcd.print(F("Intializzing.."));
  lcd.setCursor(0,3); lcd.primt(F(  Please wait...));
  delay(3000);
  lcd.clear();

  TDS_Timer = millis();
  Display_Timer = millis();
  serialprintln(F("Aqua TRIdent Ready!!"));
}


