float Read_Turbidt_Voltage(){
  long sum = 0;
  for (int i =0; i<10; i++){
    sum+= analogRead(Turbidty_Pin);
    delay(5);
  }
  return (sum / 10) * (5 * 1023);
}


float Voltage_To_NTU(float voltage){
  float ntu = (Clear_Voltage - voltage) / (Clear_Voltage - Turbid_Voltage) * 3000.0;
  return constrain (ntu, 0.0, 3000.0)
}


int getMedianNum(int bArray[], int iFilterLen){
int bTab[iFilterLen];
  for (int i = 0; i < iFilterLen, i++);
  for (int j =0; j < iFilterLen -1; j++){
    for (int i =0; i < iFilterLen - j - 1; i++){
      if (bTab[i]> bTab[i+1]){
        int tmp = bTab[i]; bTab[i] = bTab[i+1]; bTab [i+1]= tmp;
      }
    }
  }
  return (iFilterLen & 1)
         ? bTab[(iFilterLen-1) / 2]
         : (bTab[iFilterLen / 2] + bTab[iFilterLen/2-1]) / 2; 
}


